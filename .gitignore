# Maven build output
target/
*.class

# Reports and screenshots (generated at runtime — keep folders, ignore contents)reports/*
!reports/.gitkeep
screenshots/*
!screenshots/.gitkeep
logs/*
!logs/.gitkeep

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr
out/

# Eclipse
.classpath
.project
.settings/

# OS files
.DS_Store
Thumbs.db

# Config overrides (avoid committing local device settings)
config/local.properties
